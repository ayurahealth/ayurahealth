generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model UserProfile {
  id             String   @id // Maps to Clerk User ID
  email          String   @unique
  primaryDosha   String?  // e.g. "Vata-Pitta"
  vataScore      Int?     // e.g. 45
  pittaScore     Int?
  kaphaScore     Int?
  age            Int?
  gender         String?
  healthGoal     String?
  subscriptionTier   String?  // e.g. "premium", "premium-plus"
  subscriptionStatus String   @default("free") // "free", "active", "cancelled", "expired"
  subscriptionId     String?  @unique // Razorpay ID
  subscriptionExpiry DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  chatSessions   ChatSession[]
  memories       UserMemory[]
}

model ChatSession {
  id             String   @id @default(uuid())
  userId         String
  topic          String?  @default("New Consultation")
  summary        String?  @default("")
  createdAt      DateTime @default(now())
  
  user           UserProfile @relation(fields: [userId], references: [id])
  messages       Message[]
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // 'user' or 'assistant'
  content   String
  createdAt DateTime @default(now())
  
  session   ChatSession @relation(fields: [sessionId], references: [id])
}

model UserMemory {
  id             String   @id @default(uuid())
  userId         String
  content        String
  embedding      Unsupported("vector(384)")?
  category       String   // e.g., "Health Fact", "Preference", "Metric"
  source         String   // e.g., "Chat", "Manual", "Report"
  createdAt      DateTime @default(now())

  user           UserProfile @relation(fields: [userId], references: [id])
}

model KnowledgeChunk {
  id             String   @id @default(uuid())
  title          String
  content        String
  embedding      Unsupported("vector(384)")?
  source         String   // e.g., "Charaka Samhita", "Modern Science"
  tradition      String?  // e.g., "Ayurveda", "TCM"
  tags           String[]
  createdAt      DateTime @default(now())
}

model ClinicLead {
  id           String   @id @default(uuid())
  clinicName   String
  contactName  String
  email        String
  phone        String?
  tradition    String?  // e.g., Ayurveda, Kampo
  patientCount String?  // e.g., "100-500/mo"
  message      String?
  status       String   @default("New") // New, Contacted, Converted
  createdAt    DateTime @default(now())
}
