generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id             String   @id // Maps to Clerk User ID
  email          String   @unique
  primaryDosha   String?  // e.g. "Vata-Pitta"
  vataScore      Int?     // e.g. 45
  pittaScore     Int?
  kaphaScore     Int?
  subscriptionTier   String?  // e.g. "premium", "premium-plus"
  subscriptionStatus String   @default("free") // "free", "active", "cancelled", "expired"
  subscriptionId     String?  @unique // Razorpay ID
  subscriptionExpiry DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  chatSessions   ChatSession[]
}

model ChatSession {
  id             String   @id @default(uuid())
  userId         String
  topic          String
  summary        String
  createdAt      DateTime @default(now())
  
  user           UserProfile @relation(fields: [userId], references: [id])
}

model ClinicLead {
  id           String   @id @default(uuid())
  clinicName   String
  contactName  String
  email        String
  phone        String?
  tradition    String?  // e.g., Ayurveda, Kampo
  patientCount String?  // e.g., "100-500/mo"
  message      String?
  status       String   @default("New") // New, Contacted, Converted
  createdAt    DateTime @default(now())
}
