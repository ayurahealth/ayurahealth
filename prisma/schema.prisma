generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model UserProfile {
  id                 String   @id
  email              String   @unique
  primaryDosha       String?
  vataScore          Int?
  pittaScore         Int?
  kaphaScore         Int?
  age                Int?
  gender             String?
  healthGoal         String?
  conditions         String[] @default([])
  subscriptionTier   String?
  subscriptionStatus String   @default("free")
  subscriptionId     String?  @unique
  subscriptionExpiry DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  chatSessions       ChatSession[]
  memories           UserMemory[]
}

model ChatSession {
  id             String   @id @default(uuid())
  userId         String
  topic          String?  @default("New Consultation")
  summary        String?  @default("")
  createdAt      DateTime @default(now())
  
  user           UserProfile @relation(fields: [userId], references: [id])
  messages       Message[]
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  role      String   
  content   String
  createdAt DateTime @default(now())
  
  session   ChatSession @relation(fields: [sessionId], references: [id])
}

model UserMemory {
  id             String   @id @default(uuid())
  userId         String
  content        String
  embedding      Unsupported("vector(384)")?
  category       String   
  source         String   
  createdAt      DateTime @default(now())

  user           UserProfile @relation(fields: [userId], references: [id])
}

model KnowledgeChunk {
  id             String   @id @default(uuid())
  title          String
  content        String
  embedding      Unsupported("vector(384)")?
  source         String   
  tradition      String?
  tags           String[]
  createdAt      DateTime @default(now())
}

model ClinicLead {
  id           String   @id @default(uuid())
  clinicName   String
  contactName  String
  email        String
  phone        String?
  tradition    String?  
  patientCount String?
  message      String?
  status       String   @default("New") 
  createdAt    DateTime @default(now())
}
